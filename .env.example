# Database Configuration
# For MySQL (local development)
DATABASE_URL=mysql://root:password@localhost:3306/laundry_orders

# Gmail SMTP Configuration (for email sending)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your OS)
# 3. Google will generate a 16-character password
# 4. Copy that password below (without spaces)
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# Optional: Change email sender name
# GMAIL_FROM_NAME=Laundry Service
